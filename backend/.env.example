APP_NAME=VESTRA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vestra.com

# Development tools (must be false in production)
DEBUGBAR_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=json
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database credentials — set in production; never commit real values.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=vestra
DB_USERNAME=vestra
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.vestra.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=vestra_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Mail credentials — set in production; never commit real values.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="vestradetergent@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=vestra.com,www.vestra.com,admin.vestra.com

# Flutterwave credentials — set in production; never commit real values.
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Frontend URL (for payment redirects)
FRONTEND_URL=https://vestra.com

# Bootstrap administrator password.
# MUST be set to a strong value in production. The default below is for local/test only.
BOOTSTRAP_ADMIN_PASSWORD=
