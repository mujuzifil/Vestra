# ------------------------------------------------------------------------------
# VESTRA Platform — Root .gitignore
# ------------------------------------------------------------------------------

# Environment & secrets
.env
.env.backup
.env.production
.env.local
.env.*.local
!.env.example

# Dependencies
**/node_modules/
**/vendor/

# Laravel / PHP
backend/bootstrap/cache/*.php
backend/storage/app/public/*
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*
backend/storage/logs/*.log
backend/storage/logs/laravel.log*
backend/public/storage
backend/public/hot
backend/public/build
backend/.phpunit.result.cache
backend/.php-cs-fixer.cache
backend/Homestead.json
backend/Homestead.yaml
backend/npm-debug.log
backend/yarn-error.log
backend/composer.phar

# Next.js / Frontend
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Audit tooling outputs
audit-stage-8-1/node_modules/
audit-stage-8-1/screenshots*/
audit-stage-8-1/*.log

# IDE / Editor
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
*.pem

# Docker / Infrastructure
*.pid
*.seed
*.cover

# Temporary files
*.tmp
*.temp
*.cache
