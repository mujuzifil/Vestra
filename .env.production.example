# ==============================================================================
# VESTRA — Production Environment Template
# ==============================================================================
#
# Copy to `.env.production` on the VPS and fill in real values:
#
#     cp .env.production.example .env.production
#     chmod 600 .env.production
#     chown root:root .env.production
#
# NEVER commit .env.production. Only this template is tracked.
# Generate every secret fresh — see docs/release/SECRET_ROTATION_CHECKLIST.md
# ==============================================================================

# ------------------------------------------------------------------------------
# Deployment image tags
# ------------------------------------------------------------------------------
# Registry namespace and the image tag to run. `deploy.sh` rewrites IMAGE_TAG on
# each release; `rollback.sh` rewrites it to a previous tag. Keep PREVIOUS_TAG
# updated so rollback has a target.
DOCKER_REGISTRY=docker.io/your-dockerhub-user
IMAGE_TAG=latest
PREVIOUS_TAG=

# ------------------------------------------------------------------------------
# Domains
# ------------------------------------------------------------------------------
# Bare hostnames (no scheme) — consumed by the nginx reverse proxy.
APP_DOMAIN=vestra.com
API_DOMAIN=api.vestra.com
ADMIN_DOMAIN=admin.vestra.com

# ------------------------------------------------------------------------------
# Laravel application
# ------------------------------------------------------------------------------
APP_NAME=VESTRA
APP_ENV=production
APP_DEBUG=false
DEBUGBAR_ENABLED=false

# Generate with: docker compose run --rm backend php artisan key:generate --show
# The application cannot decrypt stored settings without this. NEVER change it
# after go-live — doing so renders all encrypted settings unreadable.
APP_KEY=

APP_URL=https://api.vestra.com
FRONTEND_URL=https://vestra.com

# Reverse-proxy IPs/CIDRs to trust for X-Forwarded-* headers.
# "*" is correct only because nginx is the sole ingress on the internal
# docker network and ports 3000/8000 are not published to the host.
TRUSTED_PROXIES=*

# ------------------------------------------------------------------------------
# CORS — browser origins allowed to call the API
# ------------------------------------------------------------------------------
# Comma-separated, scheme included, no trailing slash.
# Omitting this collapses the allowed origin to APP_URL (the API domain) and
# blocks every storefront request. See backend/config/cors.php.
CORS_ALLOWED_ORIGINS=https://vestra.com,https://www.vestra.com,https://admin.vestra.com

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DB_DATABASE=vestra
DB_USERNAME=vestra
# openssl rand -base64 32
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ------------------------------------------------------------------------------
# Redis — cache, queue and session backend
# ------------------------------------------------------------------------------
# openssl rand -base64 32
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# Session & Sanctum
# ------------------------------------------------------------------------------
# SESSION_SECURE_COOKIE=true requires HTTPS. Over plain HTTP the browser
# silently discards the cookie and admin login fails with no error.
SESSION_DOMAIN=.vestra.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=vestra.com,www.vestra.com,admin.vestra.com
SANCTUM_TOKEN_EXPIRATION=10080

# ------------------------------------------------------------------------------
# Mail
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=vestradetergent@gmail.com
MAIL_FROM_NAME=VESTRA

# ------------------------------------------------------------------------------
# Flutterwave payments — LIVE keys
# ------------------------------------------------------------------------------
# FLUTTERWAVE_WEBHOOK_SECRET must match the "Secret hash" in the Flutterwave
# dashboard exactly, or every incoming webhook is rejected as unsigned.
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Bootstrap administrator
# ------------------------------------------------------------------------------
# The application refuses to boot in production while the default password is in
# use. Must be strong and unique.
BOOTSTRAP_ADMIN_PASSWORD=

# ------------------------------------------------------------------------------
# Frontend build-time configuration
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_* values are INLINED INTO THE CLIENT BUNDLE AT BUILD TIME.
# Changing them requires a frontend image rebuild — restarting the container
# has no effect. They are passed as build args in docker-compose.prod.yml.
NEXT_PUBLIC_API_URL=https://api.vestra.com/api/v1
NEXT_PUBLIC_SITE_URL=https://vestra.com
NEXT_PUBLIC_BACKEND_URL=https://api.vestra.com
NEXT_PUBLIC_CDN_HOST=

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ------------------------------------------------------------------------------
# Backups
# ------------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
